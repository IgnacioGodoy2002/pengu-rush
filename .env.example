# ─── SURA Integration ────────────────────────────────────────────────────────
#
# All variables are OPTIONAL in standalone mode (the default).
# Copy this file to .env and fill in the values when integrating with SURA.
#
# ⚠ Never commit a real .env file — it is listed in .gitignore.

# Integration mode in production.
# Accepted values: "sura" | (anything else → standalone)
# "sura-mock" is only available in development via ?sura_mode=mock in the URL.
VITE_SURA_INTEGRATION_MODE=

# Origin of the SURA parent application (no trailing slash).
# Required when VITE_SURA_INTEGRATION_MODE=sura.
# Example: https://app.sura.com.ar
VITE_SURA_PARENT_ORIGIN=

# Base URL of the SURA API (no trailing slash).
# Required when VITE_SURA_INTEGRATION_MODE=sura.
# Example: https://api.sura.com.ar/v1
VITE_SURA_API_BASE_URL=

# Game identifier assigned by SURA (provisional — subject to change).
# Defaults to "pengu_rush" if not set.
VITE_SURA_GAME_ID=pengu_rush

# Game version reported to SURA on MINIGAME_READY.
# Defaults to "1.0.0" if not set.
VITE_SURA_GAME_VERSION=1.0.0
